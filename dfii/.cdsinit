; replace Cadence function for opening schematic properties with this one
; to fix Linux problem (form size too small)
; attention: this workaround seems to cause another problem...a 5s delay on
; closing the form? Delay depends on Linux distribution.
procedure( TIsopCB2( l_newSize "l" )
    let( ((initSize schObjPropForm->initialSize))
    if(cadr(l_newSize) < 200 then
      Debug(10 "newSize=%L initSize=%L\n" l_newSize initSize)
      Debug(10 "catched wrong form size error (type 1)\n")
      l_newSize = list(car(l_newSize) 725)
    )
    hiSetFormSize(schObjPropForm l_newSize)
    if(cadr(initSize) > 200 then
      schObjPropForm->initialSize = initSize
    else
      Debug(10 "newSize=%L initSize=%L\n" l_newSize initSize)
      Debug(10 "catched wrong form size error (type 2)\n")
      schObjPropForm->initialSize = l_newSize
    )
  )
) ; TIsopCB2
procedure( TIsopCB1( )
    hiRegTimer(sprintf( nil "TIsopCB2('%L)" hiiGetFormSize(schObjPropForm) ) 6) ; means 6 10th-of-seconds
) ; TIsopCB1
procedure( TIschObjProp( )
    hiRegTimer( "TIsopCB1()" 1 ) ; means 1 10th-of-seconds
    schHiObjectProperty()
) ; TIschObjProp
; enable debug messages up to level 10
; DEBUG=10
; try to switch off echCommands in DRC and Extract
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;try to fix bug with unbound variables during loading virtuoso
;;this procedure will load layerProc.cxt file
;;initalize form and we will have access to it.
procedure( createAndSetForms()
    iviCreateExtForm();
    hiInstantiateForm(ivExtOptionsForm);
    ivExtOptionsForm->echoCommands->value = nil;
    iviCreateDRCForm();
    hiInstantiateForm(ivDRCOptionsForm);
    ivDRCOptionsForm->echoCommands->value = nil;
)
  unless( (boundp( 'ivDRCOptionsForm ) != nil)
     createAndSetForms();
  );
  unless( (boundp( 'ivExtOptionsForm ) != nil)
     createAndSetForms();
  );
ihpCdfUpdCreateMenu()
