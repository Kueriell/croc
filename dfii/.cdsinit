SetupGDSForm()
;------------------------------
; Personal preferences:
;-----------------------------
editor = "nedit"
;;remove loading of the onGrid because in loading in tools.il file.
loadi("tluForm.il")
; Multipath templates
printf("Loading MPP templates\n")
load(strcat(SG13_IHP_TECH "/lib/SG13_dev/mpp_templates.il"))
; Innovus
when( getShellEnvVar("INNOVUSHOME")
   printf("Init Innovus\n")
   loadi(strcat(getShellEnvVar("INNOVUSHOME") "/tools/innovus/gift/AoT/VEXface/virLaunchInnovusIC61x.il"))
)
; Enable the Create->Geometric Wire functionality
envSetVal( "we" "mixedSignalWireEditingEnvironment" 'boolean t )
; Avoids "|" sign for instances
envSetVal("layoutXL" "prefixLayoutInstNamesWithPipe" 'boolean nil)
;Load LiberateAMS GUI
liberateHome = getShellEnvVar("LIBERATEHOME")
unless(liberateHome liberateHome = getShellEnvVar("ALTOSHOME"))
if(liberateHome then
    elib = strcat(liberateHome "/etc/liberate_gui.il.e")
    printf("[INFO] %s\n" "Loading Liberate AMS environment")
    load(elib)
    ;Set up netlisting for post-layout Liberate AMS compatibility
    envSetVal("asimenv" "mappingMode" 'string "oss")
    hnlSpectreMapNetInName='(
        (">" "\\>")
        ("<" "\\<")
        ("." "_")
        ("#" "\\#")
        ("$" "\\$")
        ("%" "\\%")
        ("^" "\\^")
        ("&" "\\&")
        ("*" "\\*")
        ("(" "_")
        (")" "")
        ("\\" "\\\\")
        ("|" "_")
        ("+" "\\+")
        ("-" "\\-")
        ("=" "\\=")
        ("{" "\\{")
        ("}" "\\}")
        ("[" "\\[")
        ("]" "\\]")
        ("\"" "\\\"")
        ("'" "\\'")
        (":" "_")
        (";" "\\;")
        ("~" "\\~")
        ("`" "\\`")
        ("," "\\,")
        ("?" "\\?")
        ("/" "\\/")
        ("@" "\\@")
    )
    printf( "[INFO] Liberate AMS setup was executed  \n")
)
