              strcat(SG13_IHP_TECH "/env") strcat(SG13_IHP_TECH "/lib/SG13_dev") )
  if( isDir(strcat(SG13_IHP_TECH "/il/pCells")) tmp = append1(tmp strcat(SG13_IHP_TECH "/il/pCells")) )
  test = setSkillPath( append( tmp getSkillPath() ) ) ; extended search path
  foreach( i test
    if( member(i tmp) warn("Invalid Skill search path: %L" i) )
  )
)
