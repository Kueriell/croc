setShellEnvVar("PVSUI_DRC_PRESETS_FILE" strcat(SG13_IHP_TECH "/PVS_SG13/cds/pvsDRC_preset"));
setShellEnvVar("PVSUI_LVS_PRESETS_FILE" strcat(SG13_IHP_TECH "/PVS_SG13/cds/pvsLVS_preset"));
;; load per default the .simrc file from $IHP_TECH/work/skel/cds
setShellEnvVar("SIMRC" "$IHP_TECH/work/skel/cds/");
