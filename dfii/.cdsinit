; - fix error with PROJECT path under dfii, the folder cds/ was required, which we don't have, remove this cds folder
; - fix license issue
; v1.1 - <muheim@ee.ethz.ch> - Fri Oct 29 16:39:44 CEST 2021
;  - add EMX integration 
;  - added Calibre startup loader
;

printf("[INFO] Start cdsinit.\n")
; design kit installation path
SG13_IHP_TECH=getShellEnvVar("IHP_TECH");
; path of user data and library tree
SG13_PROJECT=getShellEnvVar("PROJECT");
; path to digital libraries
SG13_IHP_DIGLIBS = getShellEnvVar("IHP_DIGLIBS");

;this cdsLibMgr.il will try to load another cdsLibMgr.il inside project directory /dfii/cds/cdsLibMgr.il,
;we don't have this and other settings are copied below
;if(isFile(strcat(SG13_IHP_TECH "/il/cdsLibMgr.il"))
;  loadi(strcat(SG13_IHP_TECH "/il/cdsLibMgr.il"))
;);

; setup technology and deskit information
loadi(strcat(SG13_IHP_TECH "/lib/SG13_dev/prop.db"))
;show categories in libraryManager
envSetVal("cdsLibManager.main" "showCategoriesOn" 'boolean t)
let((envFile)
  when(isFile(envFile=strcat(SG13_IHP_TECH "/env/cdsenv")) ; load minimum settings from env/ dir, overwrite with later definitions
     envLoadFile(envFile) ; Load initial local environment. Standard ~/.cdsenv will override our default values
  ) ; when ; because it is loaded later
) ; let
 loadi(strcat(SG13_IHP_TECH "/env/schBindKeys.il")) ; setup bindkey information
 loadi(strcat(SG13_IHP_TECH "/env/leBindKeys.il"))
 loadi(strcat(SG13_IHP_TECH "/env/wheelmouse.il")) ; add wheelmouse support
 loadi(strcat(SG13_IHP_TECH "/env/ConfigIHPPDK.il")) ;
 loadi(strcat(SG13_IHP_TECH "/env/load_modules.dz.il"))
 loadi(strcat(SG13_IHP_TECH "/il/callback_trigger.il"))
 loadi(strcat(SG13_IHP_TECH "/il/ihpUpdateCdf.il"))
;; to copy a slit or fill cell to the original one:
 loadi(strcat(SG13_IHP_TECH "/il/cpFillViews.il"))
unless(boundp('SG13_LIBRARY)
  SG13_LIBRARY = "SG13_dev" ; where to look
)
PDK_LIBRARY = "SG13_dev"
