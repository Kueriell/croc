liberate_unified_macro_token=t
;loading predefined file to block selected devices in QRC to avoid double counting of parasitics
procedure( vuiUserDefinedRCXFormSetupCB(form)
    let( ( page1 page2 page3 page4 page5 page6 blocking_file)
        blocking_file = strcat(SG13_IHP_TECH "/PVS_SG13/blocking_cells_file")
    when( form->hiFormSym == 'vuiRcxRunForm
            page1 = _vuiRcxGetTabField("vuiRcxRunForm" "setupTab")
            page2 = _vuiRcxGetTabField("vuiRcxRunForm" "extractTab")
            page3 = _vuiRcxGetTabField("vuiRcxRunForm" "filterTab")
            page4 = _vuiRcxGetTabField("vuiRcxRunForm" "netlistTab")
            page5 = _vuiRcxGetTabField("vuiRcxRunForm" "runTab")
            page6 = _vuiRcxGetTabField("vuiRcxRunForm" "snaTab")
      if(isFile(blocking_file)
              ;; Set Field values in Setup Tab
              page2->parasBlockDevCellsFile->value = blocking_file
      );
        ); end of when
        t ; a true return value is necessary
    ); end of let
); end of procedure vuiUserDefinedRCXFormSetupCB
; EMX Setup: requires EMX install dir and config file in cds directory
EMXInstallDir = getShellEnvVar("EMXHOME")
when( EMXInstallDir
    file= strcat(SG13_IHP_TECH "/lib/SG13_dev/emxconfig.il")
    when(isFile(file)
        printf("Loading the EMX setup...\n")
        loadi(file);
        printf("EMX setup loaded.\n")
    );
)
; Analog FastSPICE (AFS)
afsInstallDir = getShellEnvVar("AFS_ROOT")
when( afsInstallDir
    printf("Loading the AFS integration...\n")
    load(strcat(getShellEnvVar("AFS_ROOT") "/3rdParty/cdsinit-bda"))
    printf("AFS loaded.\n")
)
;------------------------------
printf("DZ: BEGIN OF LOCAL CUSTOMIZATION LOADING\n")

let( ( localLibPath addon addonsL )

  localLibPath = "./.init/"

  addonsL = '(
               "loadKit.il"
               "loadUserCust.il"
               "loadCalibreInteractive.il"
               "emxconfig.il"
               "loadPathwave_ads.il"
               "loadPathwave_rfic.il"
             )

  foreach( addon addonsL
    if( isFile( strcat( localLibPath addon ) ) then
        printf( "DZ: load '%s' \n" strcat( localLibPath addon ) )
        load( strcat( localLibPath addon ) )
    else
        printf( "DZ: ERROR: load '%s' -> no such file!\n" strcat( localLibPath addon ) )
    )
  );foreach
);let


;------------------------------
; RFpro
;-----------------------------
when(getShellEnvVar("HPEESOF_DIR")
  fileName = strcat(getShellEnvVar("HPEESOF_DIR") "/idf/config/.cdsinit")
  if( isFile( fileName ) then
    load( fileName ) )
)

;some settings for the ruler
envSetVal("layout" "saveRulers" 'boolean nil)
envSetVal("layout" "ruleGravityOn" 'boolean nil)

;envSetVal("layout" "useRulerSnapModes" 'boolean t)
;envSetVal("layout" "rulerSnapTarget" 'cyclic "Edges")
;;leSetEnv("rulerSnapTarget" "Edges and Points")
;;single-segment
;envSetVal("layout" "rulerSegSnapMode" 'string "orthogonal")
;;multi-segment
;envSetVal("layout" "rulerSnapMode" 'string "orthogonal")

printf("[INFO] End cdsinit.\n")

