;; Calibre DFII integration
;;---------------------------------


  ;;setup calibre
  calibreIntegration();
  let(
      (cal_file cal_file2 calFileList)
      ;;calibre post triiger
      cal_file = strcat(getShellEnvVar("IHP_TECH") "/Calibre/Skill/instFill.il");
      cal_file2 = strcat(getShellEnvVar("IHP_TECH") "/Calibre/Skill/calCellMapGen.il");
      calFileList = list(cal_file cal_file2)
      foreach(file calFileList
         when(isFile(file)
            loadi(file);
         );
      );end foreach
  );end let
;;---------------------------------
;; auCdl Schematic Netlist Export Setup for Mentor Calibre
;;---------------------------------
  loadi(strcat(SG13_IHP_TECH "/lib/SG13_dev/cdlNetlistExportSetup.il") );
unless(boundp('SG13_TFID)
  SG13_TFID = techGetTechFile(ddGetObj(SG13_LIBRARY)) ; get the techFile
)
unless(boundp('SG13_GRID)
  SG13_GRID = techGetMfgGridResolution(SG13_TFID) ; grid in [um]
)
; define some general (common) environment settings:
envSetVal( "asimenv.startup" "projectDir" 'string "./sim")
envSetVal("asimenv.startup" "simulator" 'string "spectre")
envSetVal("graphic" "drfPath" 'string strcat(SG13_IHP_TECH "/env/display.drf"))
; default dir for new libs
envSetVal("ddserv.lib" "newLibDir" 'string strcat(SG13_PROJECT "/cds"))
envSetVal("layout" "xSnapSpacing" 'float 0.01)
envSetVal("layout" "ySnapSpacing" 'float 0.01)
envSetVal("layout" "extractStopLevel" 'int 2)  ; shouldn't that be layoutXL?
envSetVal("layout" "displayPinNames" 'boolean t)
envSetVal("layout" "dynamicHilightOn" 'boolean t)
; draw cursor as crosshair
